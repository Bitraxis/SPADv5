// Test IO functions: read and write

var testFile: String = "test_data.txt"
var message: String = "Hello from SPAD!"

// Write a test file
write(testFile, message)

// Read it back
var content: String = read(testFile)

// Print what we read
print(content)

// Verify it matches
if eq(content, message)
  print("✓ IO test passed!")
else
  print("✗ IO test failed!")
